<!doctype html><html><head><meta charset="utf-8"><title>{{ title }}</title><style>
body{font-family:Inter,Arial,sans-serif;margin:0;background:#f8fafc;color:#0f172a}.wrap{max-width:1100px;margin:0 auto;padding:32px}.card{background:white;border:1px solid #e2e8f0;border-radius:16px;padding:28px;box-shadow:0 8px 24px #0001}h1,h2{color:#1e3a8a}table{width:100%;border-collapse:collapse;margin:16px 0}th,td{border:1px solid #cbd5e1;padding:8px;text-align:left}th{background:#eff6ff}code{background:#e2e8f0;padding:2px 5px;border-radius:4px}.badges{display:flex;gap:8px;flex-wrap:wrap}.badge{border-radius:999px;padding:4px 10px;font-weight:700}.critical{background:#7f1d1d;color:#fff}.high{background:#dc2626;color:#fff}.medium{background:#f59e0b}.low{background:#38bdf8}.info{background:#e2e8f0}</style></head><body><main class="wrap"><section class="card"><h1>{{ title }}</h1><div class="badges">{% for severity,count in risk_summary.items() %}<span class="badge {{ severity }}">{{ severity }}: {{ count }}</span>{% endfor %}</div><hr>{{ content|safe }}</section></main></body></html>
