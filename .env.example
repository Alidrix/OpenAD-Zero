# OpenAD-Zero development example. Copy to .env and replace placeholders before exposing the stack.
OPENADZERO_ENV=dev
OPENADZERO_AUTO_MIGRATE=false
OPENADZERO_REQUIRE_SCHEMA_READY=false
OPENADZERO_API_TOKEN_FILE=
POSTGRES_PASSWORD_FILE=
BLOODHOUND_API_TOKEN_FILE=
NEO4J_PASSWORD_FILE=
POSTGRES_PASSWORD=change-me-dev-postgres
NEO4J_PASSWORD=change-me-dev-neo4j
ALLOW_PUBLIC_SCANS=false
NMAP_TIMEOUT_SECONDS=900
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
BLOODHOUND_ENABLED=false
BLOODHOUND_BASE_URL=http://bloodhound:8080
BLOODHOUND_API_TOKEN=
BLOODHOUND_VERIFY_TLS=false
BLOODHOUND_INGEST_TIMEOUT=300
BLOODHOUND_POSTGRES_USER=bloodhound
BLOODHOUND_POSTGRES_PASSWORD=change-me-bloodhound
BLOODHOUND_POSTGRES_DB=bloodhound
BLOODHOUND_NEO4J_AUTH=neo4j/change-me-neo4j


OPENADZERO_AUTO_CREATE_TABLES=false
OPENADZERO_RUN_MIGRATIONS_ON_STARTUP=false
OPENADZERO_DEFAULT_MODE=safe
OPENADZERO_ENABLE_ASSISTED_MODE=true
OPENADZERO_ENABLE_CTF_LAB_MODE=false
OPENADZERO_ENABLE_MANUAL_ACTION_CARDS=false
OPENADZERO_ENABLE_EXTERNAL_EVIDENCE_IMPORT=true
OPENADZERO_ENABLE_REPORTING=false
OPENADZERO_ENABLE_AI_PLANNER=false
OPENADZERO_ENABLE_ADVANCED_AUTOMATION=false

OPENADZERO_AUTH_ENABLED=false
OPENADZERO_API_TOKEN=
OPENADZERO_ALLOW_UNAUTHENTICATED_LOCALHOST=true
OPENADZERO_AUTH_PROTECT_DOCS=false
OPENADZERO_APPROVAL_TTL_SECONDS=900

EXTERNAL_EVIDENCE_MAX_UPLOAD_MB=100
EXTERNAL_EVIDENCE_ALLOWED_EXTENSIONS=.txt,.log,.json,.jsonl,.xml,.csv,.zip,.png,.jpg,.jpeg,.md
EXTERNAL_EVIDENCE_PREVIEW_MAX_BYTES=200000
OPENADZERO_ACTION_JOB_TIMEOUT_SECONDS=900
OPENADZERO_ACTION_JOB_TTL_SECONDS=300
OPENADZERO_ACTION_RESULT_TTL_SECONDS=86400

OPENADZERO_PROCESS_LOG_TAIL_BYTES=20000
OPENADZERO_PROCESS_MAX_LOG_BYTES=5000000
